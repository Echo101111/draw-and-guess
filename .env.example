# Server Configuration
NODE_ENV=development
PORT=3000
CLIENT_URL=http://localhost:5173

# Client Configuration (Vite build-time env)
# VITE_SERVER_URL=http://localhost:3000

# Production Configuration (docker-compose)
# 创建 .env 文件并设置以下变量：
# CLIENT_URL=https://yourdomain.com     # 用户访问的前端地址，用于 CORS
# CLIENT_URL 支持逗号分隔多个地址，如：https://a.com,https://b.com
# VITE_SERVER_URL=                       # 留空 = 同源代理（通过 nginx），设置则直接连接服务器

# Deployment Configuration (scripts/deploy.sh)
# SERVER_IP=123.45.67.89                # 云服务器 IP（必填）
# SSH_USER=ubuntu                       # SSH 用户名（可选，默认 ubuntu）
